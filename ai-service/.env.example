PORT=8001
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional model/quality tuning
INSIGHTFACE_MODEL=buffalo_s
INSIGHTFACE_DET_SIZE=640
EMBEDDING_CACHE_TTL_SECONDS=300
MIN_CANDIDATE_THRESHOLD=0.35
MATCH_TOP_K=3
MAX_EMBEDDINGS_PER_STUDENT=10
MIN_MATCH_MARGIN=0.03
FACE_MIN_BRIGHTNESS=0.22
FACE_MIN_BLUR_VARIANCE=60.0
FACE_MIN_AREA_RATIO=0.07
FACE_GUIDE_MIN_AREA_RATIO=0.035
FACE_MAX_CENTER_OFFSET=0.38
ENABLE_CAPTURE_RECOVERY=true
FACE_RECOVERY_MIN_BRIGHTNESS=0.16
FACE_RECOVERY_MIN_BLUR_VARIANCE=22.0
FACE_RECOVERY_TARGET_BRIGHTNESS=0.34
FACE_RECOVERY_MIN_QUALITY_SCORE=0.18
FACE_RECOVERY_CLAHE_CLIP_LIMIT=2.5
FACE_RECOVERY_CLAHE_TILE_GRID=8
FACE_RECOVERY_UNSHARP_SIGMA=1.4
FACE_RECOVERY_UNSHARP_AMOUNT=1.15
GUIDE_ELLIPSE_CENTER_X=0.50
GUIDE_ELLIPSE_CENTER_Y=0.50
GUIDE_ELLIPSE_RADIUS_X=0.23
GUIDE_ELLIPSE_RADIUS_Y=0.39
GUIDE_ELLIPSE_TOLERANCE=1.00
GUIDE_CROP_PADDING_RATIO=0.14
